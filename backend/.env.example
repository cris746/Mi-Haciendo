# =============================================
# MI HACIENDA — Variables de Entorno Backend
# Copia este archivo como .env y completa
# los valores reales. NUNCA subas .env a Git.
# =============================================

# Puerto del servidor Express
PORT=3001

# Conexión a PostgreSQL
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
DATABASE_URL="postgresql://postgres:TU_CONTRASEÑA@localhost:5432/Mi_Hacienda"

# Clave secreta para firmar tokens JWT
# Genera una segura con: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET="reemplaza_con_una_clave_muy_larga_y_aleatoria"

# Entorno de ejecución: development | production
NODE_ENV=development
